<%- include('partials/header', { title: 'Create an Account' }) %>

  <section class="hero hero--compact">
    <p class="hero__eyebrow">Get started</p>
    <h1 class="hero__title">Create your account</h1>
    <p class="hero__subtitle">Sign up to generate QR codes and manage them from your own dashboard.</p>
  </section>

  <div class="auth-shell">
    <div class="panel panel--auth">
      <h2 class="panel__title">Register</h2>

      <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
        <div class="alert alert--error" role="alert">
          <strong>Please fix the following:</strong>
          <ul>
            <% errors.forEach(function(err) { %>
              <li><%= err.msg %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <form action="/register" method="POST" novalidate>
        <div class="field">
          <label for="username" class="field-label">Username</label>
          <input
            type="text"
            id="username"
            name="username"
            class="field-input"
            autocomplete="username"
            maxlength="30"
            value="<%= (typeof formData !== 'undefined' && formData.username) ? formData.username : '' %>"
            required
          />
          <p class="field-hint">3-30 characters: letters, numbers, and underscores only.</p>
        </div>

        <div class="field">
          <label for="email" class="field-label">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            class="field-input"
            autocomplete="email"
            maxlength="255"
            value="<%= (typeof formData !== 'undefined' && formData.email) ? formData.email : '' %>"
            required
          />
        </div>

        <div class="field">
          <label for="password" class="field-label">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            class="field-input"
            autocomplete="new-password"
            minlength="8"
            required
          />
          <p class="field-hint">At least 8 characters.</p>
        </div>

        <div class="field">
          <label for="confirmPassword" class="field-label">Confirm password</label>
          <input
            type="password"
            id="confirmPassword"
            name="confirmPassword"
            class="field-input"
            autocomplete="new-password"
            minlength="8"
            required
          />
        </div>

        <button type="submit" class="btn btn--primary">Create account</button>
      </form>

      <p class="auth-switch">Already have an account? <a href="/login">Log in</a>.</p>
    </div>
  </div>

<%- include('partials/footer') %>
