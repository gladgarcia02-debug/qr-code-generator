<%- include('partials/header', { title: typeof title !== 'undefined' ? title : 'QR Code Expired' }) %>

  <section class="error-page">
    <p class="error-page__code">▦ ▦ ▦</p>
    <h1 class="error-page__title"><%= typeof heading !== 'undefined' ? heading : 'This QR code has expired' %></h1>
    <p style="color: var(--text-on-ink-muted); max-width: 420px; margin: 0 auto 28px;">
      <%= typeof message !== 'undefined' ? message : 'This code is no longer valid.' %>
    </p>
    <a href="/" class="btn btn--primary">Generate a new QR code</a>
  </section>

<%- include('partials/footer') %>
